# ── Required ──────────────────────────────────────────────────────────────────
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-to-random-string

# ── AI day notes (optional — set by installer, fully free options below) ──────
#
# The installer will ask you to pick one. All options below are FREE.
# Leave LLM_MODEL empty (or unset) to disable AI notes entirely.
# The app works 100% offline without any LLM configured.
#
# OPTION 1 — Ollama (recommended: local, private, no key needed)
#   Install: https://ollama.com  then run:  ollama pull llama3.2
#
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=
#
# OPTION 2 — Groq (cloud, very fast, free tier at console.groq.com)
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=your_groq_key_here
# LLM_MODEL=llama-3.1-8b-instant
#
# OPTION 3 — OpenRouter (cloud, free models at openrouter.ai)
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=your_openrouter_key_here
# LLM_MODEL=meta-llama/llama-3.2-3b-instruct:free

# ── Auto-shutdown ─────────────────────────────────────────────────────────────
# Seconds of browser inactivity before the server stops (default: 1800 = 30 min)
# Set to 0 to disable auto-shutdown
IDLE_TIMEOUT=1800

# ── App ───────────────────────────────────────────────────────────────────────
PORT=5001

# ── Optional geocoding APIs (app works without these via OpenStreetMap) ───────
# OPENCAGE_API_KEY=your_opencage_api_key      # opencagedata.com — 2500 req/day free
# TIMEZONEDB_API_KEY=your_timezonedb_api_key  # timezonedb.com — free
# PROKERALA_CLIENT_ID=your_prokerala_id       # api.prokerala.com — optional panchang
# PROKERALA_CLIENT_SECRET=your_prokerala_secret
