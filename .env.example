# Copy to .env and fill in values
FLASK_SECRET_KEY=change-me-to-random-string

# OpenCage Geocoder (free tier: 2500 req/day)
# https://opencagedata.com/
OPENCAGE_API_KEY=your_opencage_api_key

# Prokerala Panchang API (optional supplement)
# https://api.prokerala.com/
PROKERALA_CLIENT_ID=your_prokerala_client_id
PROKERALA_CLIENT_SECRET=your_prokerala_client_secret

# TimeZoneDB (free tier: 1 req/sec)
# https://timezonedb.com/
TIMEZONEDB_API_KEY=your_timezonedb_api_key

# ── Open LLM (optional — enables AI Vedic day notes in iCal/Obsidian export) ──
# Works with Ollama (local/free), Groq, OpenRouter, LM Studio, or any
# OpenAI-compatible endpoint. All three vars have working defaults for Ollama.
#
# Option A — Ollama (fully local, zero cost):
#   Install: https://ollama.com  →  ollama pull llama3.2
#   Leave LLM_BASE_URL and LLM_API_KEY at defaults, just set LLM_MODEL.
#
# Option B — Groq (cloud, free tier, very fast):
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_API_KEY=your_groq_api_key        # https://console.groq.com (free)
#   LLM_MODEL=llama-3.1-8b-instant
#
# Option C — OpenRouter (cloud, many free models):
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   LLM_API_KEY=your_openrouter_key      # https://openrouter.ai (free tier)
#   LLM_MODEL=meta-llama/llama-3.2-3b-instruct:free
#
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.2

# App Settings
FLASK_ENV=production
PORT=5000
